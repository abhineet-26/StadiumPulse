# Environment variables — copy this file to .env and fill in values
# NEVER commit the .env file (it is in .gitignore)

# Optional: Gemini API key for real LLM responses
# Without this key, the app runs in fully-simulated RAG mode (recommended for demo)
# With this key, responses are generated by the Gemini model instead of templates
GEMINI_API_KEY=

# Application settings (defaults shown — only set if overriding)
# APP_HOST=0.0.0.0
# APP_PORT=8000
# RATE_LIMIT_PER_MINUTE=20
